# Supabase (required for production backbone)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (required for PayMongo webhook order updates)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for auth email redirects + PayMongo success/cancel URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PayMongo (server-only — from https://dashboard.paymongo.com Developers > API Keys)
# Use sk_test_... while testing, sk_live_... when going live.
PAYMONGO_SECRET_KEY=sk_test_your-secret-key
# From Developers > Webhooks after creating a webhook pointing to
# https://your-domain.com/api/webhooks/paymongo with events:
# checkout_session.payment.paid, payment.paid
PAYMONGO_WEBHOOK_SECRET=whsk_your-webhook-secret
